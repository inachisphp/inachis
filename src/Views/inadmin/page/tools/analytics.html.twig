{% extends "/inadmin/structure/main.html.twig" %}

{% block pagetitle %}
    <a href="{{ path('incc_tools_index') }}">Tools</a>
    <span>Analytics</span>
{% endblock pagetitle %}


{% block content %}
<section class="col-12 admonition admonition__info">
    <p><strong>Data range:</strong> {{ analytics.from|date('jS F Y') }} &mdash; {{ analytics.to|date('jS F Y') }}</p>
</section>

<div class="col-6">
    <section class="widget ui-section rounded">
        <header class="widget__header">
            <h2>Overview</h2>
        </header>
        <ul>
            <li><strong>Total Views (30 days):</strong> {{ analytics.totalViews|number_format }}</li>
            <li><strong>Unique Visitors:</strong> {{ analytics.uniqueVisitors|number_format }}</li>
            {% if analytics.change is not null %}
                <li>
                    <strong>Change:</strong>
                    {{ analytics.change > 0 ? '+' : '' }}{{ analytics.change|number_format }}%
                </li>
            {% endif %}
        </ul>
    </section>

    <!-- section class="widget ui-section">
        <header class="widget__header">
            <h2>Top Referrers</h2>
        </header>
        <p>Not implemented yet.</p>
    </section -->
</div>

<section class="col-6 widget">
    <header class="widget__header">
        <h2>Traffic (last 30 days)</h2>
    </header>
    <canvas id="trafficChart"></canvas>
</section>

<section class="col-6 widget">
    <header class="widget__header">
        <h2>Top Pages</h2>
    </header>
    <table>
        <thead>
            <tr>
                <th>Page</th>
                <th>Views</th>
                <th>%</th>
            </tr>
        </thead>
        <tbody>
            {% for page in analytics.topPages %}
                <tr>
                    <td>{{ page.title }}</td>
                    <td>{{ page.total }}</td>
                    <td>{{ (page.total / analytics.totalViews * 100)|number_format(1) }}</td>
                </tr>
            {% else %}
                <tr><td colspan="3">No data</td></tr>
            {% endfor %}
        </tbody>
    </table>
</section>

<section class="col-6 widget">
    <header class="widget__header">
        <h2>Top 404s</h2>
    </header>
    <table>
        <thead>
            <tr>
                <th>Path</th>
                <th>Hits</th>
            </tr>
        </thead>
        <tbody>
            {% for page in analytics.top404s %}
                <tr>
                    <td>{{ page.path }}</td>
                    <td>{{ page.hits }}</td>
                </tr>
            {% else %}
                <tr><td colspan="2">No data</td></tr>
            {% endfor %}
        </tbody>
    </table>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
	const views = {{ analytics.viewsPerDay|map(v => v.total)|json_encode|raw }};
	const avg = views.reduce((a, b) => a + b, 0) / views.length;
    const avgLine = views.map(() => avg);
    const data = {
        labels: {{ analytics.viewsPerDay|map(v => v.date)|json_encode|raw }},
        datasets: [
            {
                label: 'Views',
                data: {{ analytics.viewsPerDay|map(v => v.total)|json_encode|raw }},
                fill: false,
                tension: 0.2
            },
            {
                label: 'Average Views',
                data: avgLine,
                borderDash: [5, 5],
                fill: false,
                tension: 0
            }
        ]
    };
    new Chart(
        document.getElementById('trafficChart'),
        {
            type: 'line',
            data: data,
        }
    );
</script>

{% endblock content %}