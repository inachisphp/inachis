{% extends "/inadmin/structure/main.html.twig" %}
{% block pagetitle %}
    <a href="{{ path('incc_settings_index') }}">Settings</a>
    <span>robots.txt Configuration</span>
{% endblock pagetitle %}
{% block content %}

<form method="post">
    <div class="card">
        <div class="card-header">
            robots.txt
        </div>

        <div class="card-body">
            <p>
                Enter the contents of your robots.txt file below.
                The sitemap URL will be appended automatically.
            </p>

            <textarea
                name="robots_txt"
                rows="20"
                class="form-control font-monospace"
            >{{ robotsTxt }}</textarea>
        </div>

        <div class="card-footer">
            <button
                type="submit"
                class="btn btn-primary"
            >
                Save
            </button>
        </div>
    </div>
</form>

{% endblock content %}