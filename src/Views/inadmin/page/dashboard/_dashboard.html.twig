{% extends "/inadmin/structure/main.html.twig" %}

{% block pagetitle %}
    <span>{% trans %}admin.dashboard.title{% endtrans %}</span>
{% endblock pagetitle %}

{% block content %}
{% block dashboard_pre %}{% endblock dashboard_pre %}
{% block dashboard %}
    <div class="col-6">
        <h2>Welcome back {{ app.user.displayName }},</h2>
        {% if dashboard.alerts|default([]) is not empty %}
            <!-- add widget here for site warnings such as large images -->
            {% include "inadmin/page/dashboard/alerts.html.twig" %}
        {% else %}
            {% include "inadmin/page/dashboard/actions.html.twig" %}
        {% endif %}
    </div>
    <div class="col-6">
        {% include "inadmin/page/dashboard/stats.html.twig" %}
    </div>

    <div class="col-6">
        {% include "inadmin/page/dashboard/_posts.html.twig" %}
    </div>
    <div class="col-6">
        {% include "inadmin/page/dashboard/_series.html.twig" %}
        {% include "inadmin/page/dashboard/_comments.html.twig" %}
    </div>

{% endblock dashboard %}
{% block dashboard_post %}{% endblock dashboard_post %}
{% endblock content %}