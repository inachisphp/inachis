{% if dashboard.draftSeries|default([]) is not empty or dashboard.series|default([]) is not empty  %}
<section class="widget widget-series ui-section rounded">
	<header class="widget__header">
		<h3>Series</h3>
		<ul class="ui-tabs">
			<li>
				<a href="#widget-series__drafts">Drafts</a>
			</li>
			<li>
				<a href="#widget-series__published">Published</a>
			</li>
		</ul>
	</header>

    <div id="widget-series__drafts">
		<dl>
			{% for series in dashboard.draftSeries %}
				<dt><a aria-label="Edit {{ series.title }}" href="{{ path('incc_series_edit', {'id': series.id}) }}">{{ series.title }}{{ series.subtitle ? ' - ' ~ series.subtitle }}</a></dt>
				<dd>
					<span>{{ series.items|length }}</span> posts &middot;
					<span>Updated: <em>{{ series.modDate|date('jS F Y') }}</em></span>
				</dd>
			{% endfor %}
		</dl>
	</div>
	<div id="widget-series__published">
		<dl>
			{% for series in dashboard.series %}
				<dt><a aria-label="Edit {{ series.title }}" href="{{ path('incc_series_edit', {'id': series.id}) }}">{{ series.title }}{{ series.subtitle ? ' - ' ~ series.subtitle }}</a></dt>
				<dd>
					<span>{{ series.items|length }}</span> posts &middot;
					<span>
						<em>{{ series.firstDate|date('jS F') }}</em>
						&mdash;
						<em>{{ series.lastDate|date('jS F Y') }}</em>
					</span>
				</dd>
			{% endfor %}
		</dl>
		<p class="view-all">
			<a aria-label="View all series" href="{{ path('incc_series_list') }}">View all series &rarr;</a>
		</p>
	</div>
</section>
{% endif %}
